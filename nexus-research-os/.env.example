# Environment Configuration for Nexus Research OS

# Copy this file to .env and fill in your values
# NEVER commit .env files to version control

# Application Settings
APP_NAME="Nexus Research OS"
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# Database - PostgreSQL
DATABASE_URL=postgresql+asyncpg://nexus:nexus_password@localhost:5432/nexus_research

# Vector Database - Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Graph Database - Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Redis
REDIS_URL=redis://localhost:6379/0

# Message Queue
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# LLM Configuration
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# API Keys (get these from respective providers)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# LiteLLM (optional - for unified API)
LITELM_MASTER_KEY=

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Agent Configuration
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=300

# Sandbox
SANDBOX_ENABLED=true
SANDBOX_TYPE=docker

# Storage
STORAGE_TYPE=local
STORAGE_PATH=/tmp/nexus_storage

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Multi-tenancy
ENABLE_MULTI_TENANCY=true
DEFAULT_QUOTA_DAILY_TOKENS=100000
DEFAULT_QUOTA_MONTHLY_RUNS=1000
